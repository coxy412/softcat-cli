#!/usr/bin/env python3
"""SOFT CAT Agent: {{ name }} — {{ summary }}

Generated by SOFT CAT v{{ version }}
Template: digest
"""

import os
import sys
import json
import logging
from datetime import datetime, timezone
from pathlib import Path

import anthropic
import httpx
import yaml
{% if 'feedparser' in dependencies %}
import feedparser
{% endif %}

# Setup
AGENT_DIR = Path(__file__).parent
CONFIG_FILE = AGENT_DIR / "config.yaml"
PROMPT_FILE = AGENT_DIR / "prompt.md"
OUTPUTS_DIR = AGENT_DIR / "outputs"

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.StreamHandler(),
        logging.FileHandler(AGENT_DIR / "agent.log"),
    ],
)
log = logging.getLogger("softcat.{{ name }}")


def load_config() -> dict:
    """Load agent configuration."""
    with open(CONFIG_FILE) as f:
        return yaml.safe_load(f) or {}


def load_prompt(**kwargs) -> str:
    """Load and render the prompt template."""
    template = PROMPT_FILE.read_text()
    for key, value in kwargs.items():
        template = template.replace(f"{{{{{key}}}}}", str(value))
    return template


def save_output(content: str, config: dict) -> Path:
    """Save agent output to the outputs directory."""
    OUTPUTS_DIR.mkdir(exist_ok=True)
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%d-%H%M%S")
    ext = {"markdown": "md", "json": "json", "csv": "csv", "text": "txt", "html": "html"}
    extension = ext.get(config.get("output_format", "markdown"), "md")
    filename = f"{timestamp}.{extension}"
    output_path = OUTPUTS_DIR / filename
    output_path.write_text(content)
    log.info(f"Output saved: {filename}")
    return output_path


def ping_healthcheck(config: dict, status: str = "") -> None:
    """Ping Healthchecks.io on success or failure."""
    url = config.get("healthcheck_url")
    if not url:
        return
    try:
        ping_url = f"{url}/{status}" if status else url
        httpx.get(ping_url, timeout=10)
    except Exception as e:
        log.warning(f"Healthcheck ping failed: {e}")


def fetch_sources(config: dict) -> list[dict]:
    """Fetch data from configured sources."""
    entries = []
    for source in config.get("data_sources", []):
        source_type = source.get("type", "")
        url = source.get("url", "")

        try:
            if source_type == "rss":
                feed = feedparser.parse(url)
                for entry in feed.entries[:15]:
                    entries.append({
                        "title": entry.get("title", ""),
                        "link": entry.get("link", ""),
                        "summary": entry.get("summary", "")[:500],
                        "source": feed.feed.get("title", url),
                    })
            elif source_type == "api":
                resp = httpx.get(url, timeout=30)
                resp.raise_for_status()
                data = resp.json()
                if isinstance(data, list):
                    entries.extend(data[:20])
                elif isinstance(data, dict):
                    entries.append(data)
            elif source_type == "web":
                resp = httpx.get(url, timeout=30)
                resp.raise_for_status()
                entries.append({"url": url, "content": resp.text[:5000]})
        except Exception as e:
            log.warning(f"Failed to fetch {url}: {e}")

    return entries


def run(config: dict) -> str:
    """Fetch sources, build prompt with data, call Claude to summarise."""
    client = anthropic.Anthropic()

    # Fetch fresh data
    log.info("Fetching sources...")
    entries = fetch_sources(config)
    log.info(f"Got {len(entries)} entries")

    if not entries:
        log.warning("No entries fetched. Skipping.")
        return ""

    # Build the data summary for the prompt
    data_text = json.dumps(entries[:20], indent=2, default=str)

    prompt = load_prompt(
        date=datetime.now(timezone.utc).strftime("%Y-%m-%d"),
        data=data_text,
        count=str(len(entries)),
    )

    response = client.messages.create(
        model=config.get("model", "{{ model }}"),
        max_tokens={{ max_tokens | default(2000) }},
        messages=[{"role": "user", "content": prompt}],
    )

    return response.content[0].text


def main() -> None:
    """Main entry point."""
    log.info("Agent starting: {{ name }}")

    try:
        config = load_config()
        result = run(config)
        if result:
            save_output(result, config)
        ping_healthcheck(config)
        log.info("Agent completed successfully")
    except Exception as e:
        log.error(f"Agent failed: {e}")
        try:
            config = load_config()
            ping_healthcheck(config, status="fail")
        except Exception:
            pass
        sys.exit(1)


if __name__ == "__main__":
    main()
